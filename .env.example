# =============================================================================
# AiMS Strengths Assessment — environment variables
# =============================================================================
# Copy this file to .env.local for local dev. In production, set the same keys
# in your Vercel project settings (Settings → Environment Variables).
# .env.local is gitignored; never commit real values.

# ----- Supabase -------------------------------------------------------------
# From the Supabase dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ----- Anthropic ------------------------------------------------------------
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY

# ----- Resend (optional; falls back to Supabase built-in email if unset) ----
RESEND_API_KEY=YOUR_RESEND_KEY
RESEND_FROM_EMAIL=hello@yourdomain.com

# ----- App URL --------------------------------------------------------------
# Used as the redirect target for invite / password-recovery emails.
# In production, set this to the canonical URL (e.g. https://app.example.com).
# On Vercel, if omitted, the app falls back to VERCEL_URL which is injected
# automatically per deployment (branch previews included).
NEXT_PUBLIC_APP_URL=http://localhost:3100

# ----- Seed script (dev / bootstrap only) -----------------------------------
# Used by `npm run seed:admin` to create the first system admin(s). Not needed
# in Vercel.
SEED_ADMIN_EMAIL=you@example.com
SEED_ADMIN_PASSWORD=at-least-8-chars
SEED_ADMIN_FIRST_NAME=First
SEED_ADMIN_LAST_NAME=Last

# Optional additional admins with a numeric suffix. Run:
#   npm run seed:admin -- --only=2
# to seed only the "2" set without touching the base admin.
# SEED_ADMIN_EMAIL2=
# SEED_ADMIN_PASSWORD2=
# SEED_ADMIN_FIRST_NAME2=
# SEED_ADMIN_LAST_NAME2=
